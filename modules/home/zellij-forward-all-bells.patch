+#[test]
+pub fn focused_active_pane_bell_is_reported_without_pending_notification() {
+    let size = Size {
+        cols: 121,
+        rows: 20,
+    };
+    let stacked_resize = true;
+    let mut tab = create_new_tab(size, stacked_resize);
+    let focused_pane_id = PaneId::Terminal(1);
+
+    tab.handle_pty_bytes(1, vec![7u8]).unwrap();
+
+    let (new_panes, tab_newly_set, had_bell) = tab.check_and_handle_bell_notifications(true);
+
+    assert!(
+        new_panes.is_empty(),
+        "focused pane should not get a pending notification"
+    );
+    assert!(
+        !tab.panes_with_pending_bell.contains(&focused_pane_id),
+        "focused pane should not be in panes_with_pending_bell"
+    );
+    assert!(
+        !tab.tab_has_pending_bell,
+        "active tab should not have a pending bell notification"
+    );
+    assert!(
+        tab_newly_set,
+        "tab_bell_newly_set should be true for first bell"
+    );
+    assert!(had_bell, "had_bell should be true");
+}
+
+#[test]
+pub fn repeated_focused_active_pane_bell_is_reported_even_without_new_visual_state() {
+    let size = Size {
+        cols: 121,
+        rows: 20,
+    };
+    let stacked_resize = true;
+    let mut tab = create_new_tab(size, stacked_resize);
+
+    tab.handle_pty_bytes(1, vec![7u8]).unwrap();
+    let (_, tab_newly_set, had_bell) = tab.check_and_handle_bell_notifications(true);
+    assert!(tab_newly_set, "first bell should set tab_bell_ring");
+    assert!(had_bell, "first bell should be reported");
+
+    tab.handle_pty_bytes(1, vec![7u8]).unwrap();
+    let (new_panes, tab_newly_set, had_bell) = tab.check_and_handle_bell_notifications(true);
+
+    assert!(
+        new_panes.is_empty(),
+        "focused pane should not get a pending notification"
+    );
+    assert!(
+        !tab_newly_set,
+        "second bell should not require new visual state to be reported"
+    );
+    assert!(
+        had_bell,
+        "second bell should still be reported for ANSI BEL forwarding"
+    );
+}
